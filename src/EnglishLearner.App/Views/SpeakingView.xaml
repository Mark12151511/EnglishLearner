<UserControl x:Class="EnglishLearner.App.Views.SpeakingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EnglishLearner.App.ViewModels">
    <UserControl.DataContext>
        <vm:SpeakingViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0：进度区 -->
        <StackPanel Grid.Row="0" Margin="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="口语练习" FontSize="18" FontWeight="Bold" Foreground="#333"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Progress}" FontSize="15" Foreground="#888"
                           Margin="16,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <ProgressBar Value="{Binding CurrentIndex}"
                         Maximum="{Binding TotalCount}"
                         Height="6" Margin="0,8,0,0"
                         Foreground="#4CAF50" Background="#E0E0E0"/>
        </StackPanel>

        <!-- Row 1：主卡片（始终显示，内容根据 HasWord 切换） -->
        <Border Grid.Row="1" Margin="24,0,24,12" CornerRadius="12" Background="White"
                Padding="40" x:Name="WordCard"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.08" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <!-- 有单词时的内容 -->
                <StackPanel Visibility="{Binding HasWord, Converter={StaticResource BoolVis}}"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentWord.Text}"
                               FontSize="56" FontWeight="Bold" Foreground="#333"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentWord.Phonetic}"
                               FontSize="20" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding CurrentWord.Meaning}"
                               FontSize="22" Foreground="#1E88E5"
                               HorizontalAlignment="Center" Margin="0,16,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Content="&#x1F50A; 朗读单词" Command="{Binding PlayWordCommand}"
                                Background="#E3F2FD" Foreground="#1565C0" FontSize="16"
                                Padding="20,10" Margin="0,0,16,0" Cursor="Hand"
                                Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F4D6; 朗读例句" Command="{Binding PlayExampleCommand}"
                                Background="#FFF3E0" Foreground="#E65100" FontSize="16"
                                Padding="20,10" Cursor="Hand"
                                Style="{StaticResource NavButton}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 无单词时：练习完成 -->
                <StackPanel Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="练习完成！" FontSize="32" FontWeight="Bold"
                               Foreground="#4CAF50" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="17" Foreground="#888"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2：状态操作区（四态互斥，用 Visibility 切换） -->
        <Grid Grid.Row="2" Margin="24,0,24,24">

            <!-- 状态A：待机（未录音 & 未处理 & 未出结果） -->
            <StackPanel Visibility="{Binding IsIdleState, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center">
                <Button Content="&#x1F3A4; 开始录音"
                        Command="{Binding StartRecordingCommand}"
                        Background="#F44336" Foreground="White" FontSize="18" FontWeight="SemiBold"
                        Padding="40,14" Cursor="Hand"
                        Style="{StaticResource RatingButton}"/>
                <TextBlock Text="点击麦克风开始朗读"
                           HorizontalAlignment="Center"
                           Foreground="#888" FontSize="13" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- 状态B：录音中 -->
            <StackPanel Visibility="{Binding IsRecording, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center">
                <Border Background="#D32F2F" CornerRadius="10" Padding="40,16"
                        HorizontalAlignment="Center" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="14" Height="14" Fill="White" Margin="0,0,12,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="录音中..." Foreground="White" FontSize="18"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Button Content="&#x23F9; 停止录音"
                        Command="{Binding StopRecordingCommand}"
                        Background="#FF5722" Foreground="White" FontSize="18" FontWeight="SemiBold"
                        Padding="40,14" Cursor="Hand" HorizontalAlignment="Center"
                        Style="{StaticResource RatingButton}"/>
            </StackPanel>

            <!-- 状态C：识别处理中 -->
            <StackPanel Visibility="{Binding IsProcessing, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Foreground="#2196F3"/>
                <TextBlock Text="{Binding StatusMessage}"
                           HorizontalAlignment="Center"
                           Foreground="#666" FontSize="14" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- 状态D：评分结果 -->
            <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center">
                <Border Background="White" CornerRadius="12" Padding="28,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">

                        <!-- 分数 -->
                        <TextBlock Text="{Binding ScoreText}"
                                   FontSize="42" FontWeight="Bold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="High">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="Mid">
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="Low">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{Binding ScoreEmoji}"
                                   FontSize="18" HorizontalAlignment="Center" Margin="0,4,0,12"/>

                        <!-- 词级高亮 -->
                        <ItemsControl ItemsSource="{Binding Result.WordMatches}"
                                      HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="3" Padding="6,3" CornerRadius="6"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                        <Setter Property="BorderBrush" Value="#F44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Word}" FontSize="14"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 识别文本 -->
                        <TextBlock Foreground="Gray" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,8,0,12"
                                   TextWrapping="Wrap">
                            <Run Text="识别到："/>
                            <Run Text="{Binding Result.RecognizedText, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- 操作按钮 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&#x1F504; 再试一次" Command="{Binding RetryCommand}"
                                    Background="#FF9800" Foreground="White" FontSize="15" FontWeight="SemiBold"
                                    Padding="24,10" Margin="0,0,12,0" Cursor="Hand"
                                    Style="{StaticResource RatingButton}"/>
                            <Button Content="&#x27A1; 下一个" Command="{Binding NextWordCommand}"
                                    Background="#4CAF50" Foreground="White" FontSize="15" FontWeight="SemiBold"
                                    Padding="24,10" Cursor="Hand"
                                    Style="{StaticResource RatingButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
