<UserControl x:Class="EnglishLearner.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,48,0,28" HorizontalAlignment="Center">
            <TextBlock Text="EnglishLearner" FontSize="34" FontWeight="Bold"
                       Foreground="#2196F3" HorizontalAlignment="Center"/>
            <TextBlock Text="你的英语学习伙伴" FontSize="16" Foreground="#999"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Module Cards 2x2 -->
        <UniformGrid Grid.Row="1" Rows="2" Columns="2" Margin="48,0,48,48">
            <!-- 单词学习 -->
            <Border Margin="12" Background="White" CornerRadius="16" Cursor="Hand"
                    MouseLeftButtonUp="CardWordLearning_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="36" Background="#E3F2FD"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F4D6;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="单词学习" FontSize="20" FontWeight="SemiBold" Foreground="#333"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="雅思/托福词汇记忆" FontSize="14" Foreground="#999"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 阅读理解 -->
            <Border x:Name="CardReading" Margin="12" Background="White" CornerRadius="16" Opacity="0.6">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="36" Background="#E8F5E9"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F4DD;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="阅读理解" FontSize="20" FontWeight="SemiBold" Foreground="#333"
                                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="文章阅读与练习" FontSize="14" Foreground="#999"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Border Background="#4CAF50" CornerRadius="4" Padding="8,3"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0">
                        <TextBlock Text="即将推出" FontSize="11" Foreground="White"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 听力口语 -->
            <Border Margin="12" Background="White" CornerRadius="16" Cursor="Hand"
                    MouseLeftButtonUp="CardListening_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="72" Height="72" CornerRadius="36" Background="#FFF3E0"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#x1F3A4;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="听力口语" FontSize="20" FontWeight="SemiBold" Foreground="#333"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="听力训练与口语练习" FontSize="14" Foreground="#999"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 写作练习 -->
            <Border x:Name="CardWriting" Margin="12" Background="White" CornerRadius="16" Opacity="0.6">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="36" Background="#F3E5F5"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#x270D;&#xFE0F;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="写作练习" FontSize="20" FontWeight="SemiBold" Foreground="#333"
                                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="AI 智能批改" FontSize="14" Foreground="#999"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Border Background="#9C27B0" CornerRadius="4" Padding="8,3"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0">
                        <TextBlock Text="即将推出" FontSize="11" Foreground="White"/>
                    </Border>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
