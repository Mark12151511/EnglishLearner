<UserControl x:Class="EnglishLearner.App.Views.FlashCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EnglishLearner.App.ViewModels">
    <UserControl.DataContext>
        <vm:FlashCardViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 统计栏 -->
        <Border Grid.Row="0" Background="White" Padding="20,14" Margin="0"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="已复习" FontSize="14" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ReviewedToday}" FontSize="22" FontWeight="Bold"
                               Foreground="#4CAF50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="剩余" FontSize="14" Foreground="#666" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RemainingCount}" FontSize="22" FontWeight="Bold"
                               Foreground="#FF9800" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 卡片区域 -->
        <Grid Grid.Row="1" Margin="20,16,20,8" x:Name="CardContainer">
            <!-- 正面 -->
            <Border x:Name="CardFront" Background="White" CornerRadius="12" Padding="24"
                    MouseLeftButtonDown="CardFront_MouseDown" Cursor="Hand"
                    Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="FrontScale" ScaleX="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="FrontWord" FontSize="48" FontWeight="Bold"
                                   Foreground="#333" HorizontalAlignment="Center" Text="{Binding CurrentWord.Text}"/>
                        <Button Command="{Binding SpeakCommand}" Cursor="Hand"
                                VerticalAlignment="Center" Margin="12,0,0,4"
                                ToolTip="点击发音">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="circle" Width="36" Height="36" Fill="#E3F2FD"/>
                                        <TextBlock Text="&#x1F50A;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="circle" Property="Fill" Value="#BBDEFB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="FrontPhonetic" FontSize="20"
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,12,0,0"
                               Text="{Binding CurrentWord.Phonetic}"/>
                    <TextBlock Text="点击翻转查看释义" FontSize="13" Foreground="#BBB"
                               HorizontalAlignment="Center" Margin="0,28,0,0"/>
                </StackPanel>
            </Border>

            <!-- 背面 -->
            <Border x:Name="CardBack" Background="White" CornerRadius="12" Padding="24"
                    Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="BackScale" ScaleX="0"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#555"
                               HorizontalAlignment="Center" Text="{Binding CurrentWord.Text}"/>
                    <Border Height="1" Background="#E0E0E0" Margin="0,14,0,14"/>
                    <TextBlock FontSize="30" FontWeight="Bold" Foreground="#1E88E5"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Text="{Binding CurrentWord.Meaning}"/>
                    <TextBlock FontSize="15" Foreground="#777" HorizontalAlignment="Center"
                               Margin="0,18,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               FontStyle="Italic" Text="{Binding CurrentWord.Example}"/>
                </StackPanel>
            </Border>

            <!-- 空状态 -->
            <Border x:Name="CardEmpty" Background="White" CornerRadius="12" Padding="24"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="今日复习已完成！" FontSize="28" FontWeight="Bold"
                               Foreground="#4CAF50" HorizontalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontSize="15" Foreground="#888">
                        <Run Text="共复习 "/><Run Text="{Binding ReviewedToday, Mode=OneWay}"/><Run Text=" 个单词"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: 评分按钮 -->
        <Grid Grid.Row="2" Margin="16,0,16,20" x:Name="RatingPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Again" Background="#F44336"
                    Style="{StaticResource RatingButton}" Margin="0,0,4,0"
                    Command="{Binding RateCommand}" CommandParameter="0" ToolTip="完全忘记"/>
            <Button Grid.Column="1" Content="Hard" Background="#FF9800"
                    Style="{StaticResource RatingButton}" Margin="4,0,4,0"
                    Command="{Binding RateCommand}" CommandParameter="2" ToolTip="想起来了但很困难"/>
            <Button Grid.Column="2" Content="Good" Background="#4CAF50"
                    Style="{StaticResource RatingButton}" Margin="4,0,4,0"
                    Command="{Binding RateCommand}" CommandParameter="4" ToolTip="正常回忆起来"/>
            <Button Grid.Column="3" Content="Easy" Background="#2196F3"
                    Style="{StaticResource RatingButton}" Margin="4,0,0,0"
                    Command="{Binding RateCommand}" CommandParameter="5" ToolTip="非常轻松"/>
        </Grid>
    </Grid>
</UserControl>
